{
  "name": "vetcare-pro",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema veterinario desktop local para Windows",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run infra:up && npm run db:generate && npm run db:deploy && concurrently -k -n API,DESKTOP -c cyan,magenta \"npm run dev -w @vetcare/api\" \"npm run dev -w @vetcare/desktop\"",
    "dev:services": "concurrently -k -n API,DESKTOP -c cyan,magenta \"npm run dev -w @vetcare/api\" \"npm run dev -w @vetcare/desktop\"",
    "build": "npm run db:generate && npm run build -w @vetcare/api && npm run build -w @vetcare/desktop",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "local:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/doctor.ps1",
    "local:prepare": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/prepare-local.ps1",
    "local:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/start-local.ps1",
    "release:runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/prepare-release-runtime.ps1",
    "package:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/package-windows.ps1",
    "package:win:dir": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/package-windows.ps1 -DirOnly",
    "infra:up": "docker compose up -d --wait",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f postgres",
    "db:generate": "npm run db:generate -w @vetcare/api",
    "db:migrate": "npm run db:migrate -w @vetcare/api",
    "db:deploy": "npm run db:deploy -w @vetcare/api",
    "db:studio": "npm run db:studio -w @vetcare/api"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "@prisma/dev": {
      "@hono/node-server": "1.19.13"
    }
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
